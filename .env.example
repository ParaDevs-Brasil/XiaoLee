# ═══════════════════════════════════════════════════════════════════════════════
# XiaoLee — Variáveis de Ambiente
# ═══════════════════════════════════════════════════════════════════════════════
# INSTRUÇÃO: copie este arquivo para .env e preencha os valores.
#   cp .env.example .env
#
# ⚠️  NUNCA commite o arquivo .env no repositório.
# ⚠️  Em produção, use um vault (AWS Secrets Manager, HashiCorp Vault, Doppler).
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Ambiente ─────────────────────────────────────────────────────────────────
XIAOLEE_ENV=dev                    # dev | staging | production
XIAOLEE_APP_NAME=XiaoLee Core API
XIAOLEE_APP_VERSION=2.0.0-mvp

# ─── Banco de Dados ───────────────────────────────────────────────────────────
# Desenvolvimento local: deixe vazio para usar SQLite automático.
# Docker Compose:        preenchido automaticamente pelo compose.
# Produção:              postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_URL=

# Configurações do PostgreSQL (usadas pelo docker-compose)
POSTGRES_DB=xiaolee
POSTGRES_USER=xiaolee
POSTGRES_PASSWORD=TROQUE_ESTA_SENHA_EM_PRODUCAO
POSTGRES_PORT=5432

# ─── Redis ────────────────────────────────────────────────────────────────────
# Desenvolvimento local: deixe vazio para usar rate limiter in-memory.
# Docker Compose:        preenchido automaticamente pelo compose.
# Produção:              redis://:senha@host:6379/0  |  rediss:// para TLS
REDIS_URL=
REDIS_PASSWORD=TROQUE_ESTA_SENHA_EM_PRODUCAO
REDIS_PORT=6379

# ─── Gemini AI ────────────────────────────────────────────────────────────────
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ─── Solana / Jupiter ─────────────────────────────────────────────────────────
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_CLUSTER=devnet              # devnet | mainnet-beta

# Chave privada do admin do protocolo (base58) para assinar record_swap.
# Geração: solana-keygen new --outfile admin-keypair.json
#          cat admin-keypair.json | python3 -c "import sys,json,base58; print(base58.b58encode(bytes(json.load(sys.stdin))).decode())"
# ⚠️  Em produção: NUNCA coloque aqui — use vault.
SOLANA_ADMIN_KEYPAIR_B58=

# URLs do Jupiter Aggregator
JUPITER_QUOTE_URL=https://quote-api.jup.ag/v6/quote
JUPITER_SWAP_URL=https://quote-api.jup.ag/v6/swap

# ─── Telegram ─────────────────────────────────────────────────────────────────
# Obtenha em: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=gere_um_segredo_aleatorio_aqui

# ─── X (Twitter) ──────────────────────────────────────────────────────────────
X_WEBHOOK_SECRET=gere_um_segredo_aleatorio_aqui
X_BEARER_TOKEN=
X_DM_API_BASE_URL=https://api.x.com

# ─── Helius ───────────────────────────────────────────────────────────────────
# Obtenha em: https://dev.helius.xyz/
HELIUS_API_KEY=
HELIUS_WEBHOOK_SECRET=gere_um_segredo_aleatorio_aqui

# ─── Segurança ────────────────────────────────────────────────────────────────
# Rate limiting: requests por minuto por chave
INBOUND_RATE_LIMIT_PER_MINUTE=60

# CORS: origens permitidas (separadas por vírgula)
# Desenvolvimento:  http://localhost:3000
# Produção:         https://xiaolee.io,https://www.xiaolee.io
CORS_ALLOWED_ORIGINS=http://localhost:3000

# CORS: headers permitidos (separados por vírgula)
# Produção: restrinja apenas ao necessário
CORS_ALLOWED_HEADERS=Content-Type,Authorization,Accept,X-Requested-With

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CORE_API_URL=http://localhost:8000
FRONTEND_PORT=3000
BACKEND_PORT=8000

# ─── Traction / RFB-06 ────────────────────────────────────────────────────────
# Shared secret entre o agente Arc (f0ntz) e o endpoint POST /v1/payments/settled.
# Enviar no header: X-Arc-Secret: <valor>
# Se vazio, o endpoint aceita sem autenticação (dev only — NUNCA deixe vazio em produção).
ARC_PAYMENT_SECRET=gere_um_segredo_aleatorio_aqui

# ─── Circle Payments ──────────────────────────────────────────────────────────
# Obtenha em: https://console.circle.com → Developers → API Keys
# CIRCLE_API_KEY: chave de autenticação da plataforma (formato TEST_API_KEY:... ou LIVE_API_KEY:...)
# CIRCLE_WALLET_ID: ID da wallet treasury da plataforma — de onde saem os pagamentos USDC aos creators.
CIRCLE_API_KEY=
CIRCLE_WALLET_ID=

# ─── Observabilidade ──────────────────────────────────────────────────────────
PROMETHEUS_PORT=9090

GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=TROQUE_ESTA_SENHA_EM_PRODUCAO
GRAFANA_ROOT_URL=http://localhost:3001

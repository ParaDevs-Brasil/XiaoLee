# ═══════════════════════════════════════════════════════════════════════════════
# XiaoLee — Variáveis de Ambiente
# ═══════════════════════════════════════════════════════════════════════════════
# INSTRUÇÃO: copie este arquivo para .env e preencha os valores.
#   cp .env.example .env
#
# ⚠️  NUNCA commite o arquivo .env no repositório.
# ⚠️  Em produção, use um vault (AWS Secrets Manager, HashiCorp Vault, Doppler).
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Ambiente ─────────────────────────────────────────────────────────────────
XIAOLEE_ENV=dev                    # dev | staging | production
XIAOLEE_APP_NAME=XiaoLee Core API
XIAOLEE_APP_VERSION=2.0.0-mvp

# ─── Banco de Dados ───────────────────────────────────────────────────────────
# Desenvolvimento local: deixe vazio para usar SQLite automático.
# Docker Compose:        preenchido automaticamente pelo compose.
# Produção:              postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_URL=

# Configurações do PostgreSQL (usadas pelo docker-compose)
POSTGRES_DB=xiaolee
POSTGRES_USER=xiaolee
POSTGRES_PASSWORD=TROQUE_ESTA_SENHA_EM_PRODUCAO
POSTGRES_PORT=5432

# ─── Redis ────────────────────────────────────────────────────────────────────
# Desenvolvimento local: deixe vazio para usar rate limiter in-memory.
# Docker Compose:        preenchido automaticamente pelo compose.
# Produção:              redis://:senha@host:6379/0  |  rediss:// para TLS
REDIS_URL=
REDIS_PASSWORD=TROQUE_ESTA_SENHA_EM_PRODUCAO
REDIS_PORT=6379

# ─── Provedor de LLM ──────────────────────────────────────────────────────────
# Seleciona qual IA roda o cérebro da Xiao. Opções: anthropic | gemini | deepseek | openai | ollama
# Use "anthropic" para a engine agêntica (loop multi-passo de tool-use com Claude).
LLM_PROVIDER=anthropic

# ─── Claude / Anthropic (engine agêntica) ───────────────────────────────────────
# Obtenha em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6   # claude-sonnet-4-6 (padrão) | claude-opus-4-8 (mais capaz)

# ─── Gemini AI (fallback / legado) ──────────────────────────────────────────────
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ─── Solana / Jupiter ─────────────────────────────────────────────────────────
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_CLUSTER=devnet              # devnet | mainnet-beta

# Chave privada do admin do protocolo (base58) para assinar record_swap.
# Geração: solana-keygen new --outfile admin-keypair.json
#          cat admin-keypair.json | python3 -c "import sys,json,base58; print(base58.b58encode(bytes(json.load(sys.stdin))).decode())"
# ⚠️  Em produção: NUNCA coloque aqui — use vault.
SOLANA_ADMIN_KEYPAIR_B58=

# URLs do Jupiter Aggregator
JUPITER_QUOTE_URL=https://quote-api.jup.ag/v6/quote
JUPITER_SWAP_URL=https://quote-api.jup.ag/v6/swap

# ─── Telegram ─────────────────────────────────────────────────────────────────
# Obtenha em: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=gere_um_segredo_aleatorio_aqui

# ─── X (Twitter) ──────────────────────────────────────────────────────────────
X_WEBHOOK_SECRET=gere_um_segredo_aleatorio_aqui
X_BEARER_TOKEN=
X_DM_API_BASE_URL=https://api.x.com

# ─── Helius ───────────────────────────────────────────────────────────────────
# Obtenha em: https://dev.helius.xyz/
HELIUS_API_KEY=
HELIUS_WEBHOOK_SECRET=gere_um_segredo_aleatorio_aqui

# ─── Segurança ────────────────────────────────────────────────────────────────
# Rate limiting: requests por minuto por chave
INBOUND_RATE_LIMIT_PER_MINUTE=60

# CORS: origens permitidas (separadas por vírgula)
# Desenvolvimento:  http://localhost:3000
# Produção:         https://xiaolee.io,https://www.xiaolee.io
CORS_ALLOWED_ORIGINS=http://localhost:3000

# CORS: headers permitidos (separados por vírgula)
# Produção: restrinja apenas ao necessário
CORS_ALLOWED_HEADERS=Content-Type,Authorization,Accept,X-Requested-With

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CORE_API_URL=http://localhost:8000
FRONTEND_PORT=3000
BACKEND_PORT=8000

# ─── Observabilidade ──────────────────────────────────────────────────────────
PROMETHEUS_PORT=9090

GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=TROQUE_ESTA_SENHA_EM_PRODUCAO
GRAFANA_ROOT_URL=http://localhost:3001

# ─── Engine agêntica Claude (Sprint Lepton) ───────────────────────────────────
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
AGENT_MAX_STEPS=50

# ─── Arc / Circle Programmable Wallets (W3S) ─────────────────────────────────
# Guia de setup: backend/scripts/setup_circle_wallet.py
#
# Passo 1: Acesse console.circle.com → Developer → Entity Secret → Set Secret
# Passo 2: Execute: python3 backend/scripts/setup_circle_wallet.py
# Passo 3: Cole os valores retornados abaixo e mude ARC_SANDBOX=false
#
# ⚠️  NUNCA commite CIRCLE_ENTITY_SECRET. Ele fica SÓ no .env local e no vault.
CIRCLE_API_KEY=
CIRCLE_WALLET_ID=
CIRCLE_ENTITY_SECRET=       # 32 bytes hex — apenas para setup initial, não enviado por tx
CIRCLE_BLOCKCHAIN=ETH-SEPOLIA   # ou ARC-SEPOLIA quando Circle publicar o chain name
CIRCLE_USDC_TOKEN_ID=       # resolvido automaticamente via API se vazio
ARC_SANDBOX=true            # mude para false após setup_circle_wallet.py

# RPC do Arc (Canteen testnet) — obtenha no Discord do hackathon Lepton
ARC_RPC_URL=

# ─── CCTP — Cross-Chain Transfer Protocol ────────────────────────────────────
# Traz USDC de qualquer chain EVM para o Arc. Diferencial, não pré-requisito.
# Desabilitado por padrão — ative só após Circle real estar funcionando.
CCTP_ENABLED=false

# Chave privada (hex) da carteira que assina o depositForBurn na chain fonte.
# ⚠️  Mantenha APENAS no .env local. Use uma carteira dedicada para CCTP.
CCTP_SIGNER_PRIVATE_KEY=

# Chain fonte para CCTP (default: Ethereum Sepolia)
CCTP_SOURCE_RPC=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# Contratos CCTP na chain fonte (defaults Sepolia — não altere se usar Sepolia)
CCTP_SOURCE_USDC=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238
CCTP_SOURCE_TOKEN_MESSENGER=0x9f3B8679c73C2Fef8b59B4f3444d4e156fb70AA5
CCTP_SOURCE_DOMAIN=0

# Contratos CCTP no Arc (Canteen) — preencha com os endereços do hackathon
ARC_CCTP_USDC=
ARC_CCTP_TOKEN_MESSENGER=
ARC_CCTP_MSG_TRANSMITTER=
ARC_CCTP_DOMAIN=7           # placeholder — confirme no Discord do round
